#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
#
# swaylock-screensaver -- lock the session with swaylock-plugin running an
# xscreensaver "hack" as the animated background (one instance per output via
# --command-each + windowtolayer + the packaged Xwayland wrapper).
#
# Wire it up as your idle daemon's lock command, e.g.
#   swayidle:  timeout 300 'swaylock-screensaver'  lock 'swaylock-screensaver'
#   hypridle:  lock_cmd = swaylock-screensaver
#
# The hack is chosen with swaylock-screensaver-select (rofi picker) which
# writes the name to $HACK_STATE. Per-hack tuning flags can be set in
# hacks.conf (see contrib/screensaver/README.md). Every path/knob below is
# env-overridable.
#
# Fail-safe contract: a lock trigger must never leave the session unlocked.
# Degrade chain: hack missing -> default hack -> plain swaylock-plugin ->
# $SWAYLOCK_SCREENSAVER_FALLBACK (default: swaylock) -> exit nonzero so a
# caller can chain its own fallback with `swaylock-screensaver || ...`.
#
# Developed and verified in https://github.com/syndr/hyprland-wm-config
# (4-output Hyprland workstation).

HACK_STATE="${HACK_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/swaylock-screensaver/hack}"
HACKS_CONF="${SWAYLOCK_SCREENSAVER_HACKS_CONF:-${XDG_CONFIG_HOME:-$HOME/.config}/swaylock-screensaver/hacks.conf}"
# Shipped by the swaylock-plugin packages (runs a rooted Xwayland, execs the
# hack inside it).
WRAPPER="${WRAPPER:-/usr/libexec/swaylock-plugin/example_xwayland_wrapper.py}"
DEFAULT_HACK="${DEFAULT_HACK:-xrayswarm}"
FALLBACK="${SWAYLOCK_SCREENSAVER_FALLBACK:-swaylock}"

# Hack directory: distro layouts differ; first match wins unless HACK_DIR set.
if [ -z "${HACK_DIR:-}" ]; then
    for d in /usr/libexec/xscreensaver /usr/lib/xscreensaver /usr/lib64/misc/xscreensaver; do
        [ -d "$d" ] && HACK_DIR="$d" && break
    done
    HACK_DIR="${HACK_DIR:-/usr/libexec/xscreensaver}"
fi

notify() { command -v notify-send >/dev/null && notify-send "$@"; return 0; }

if ! command -v swaylock-plugin >/dev/null; then
    command -v "$FALLBACK" >/dev/null && exec "$FALLBACK"
    notify -u critical "swaylock-screensaver" \
        "neither swaylock-plugin nor $FALLBACK found -- SESSION NOT LOCKED"
    exit 1
fi

# Runs for every lock trigger; never start a second instance.
pidof -q swaylock-plugin && exit 0

HACK="$([ -r "$HACK_STATE" ] && head -n1 "$HACK_STATE")"
HACK="${HACK:-$DEFAULT_HACK}"

# Stale state file (hack renamed/removed): fall back to the default hack first.
if [ ! -x "$HACK_DIR/$HACK" ] && [ -x "$HACK_DIR/$DEFAULT_HACK" ]; then
    notify -u low "swaylock-screensaver" \
        "hack '$HACK' not found -- using $DEFAULT_HACK"
    HACK="$DEFAULT_HACK"
fi

# Per-hack tuning flags from hacks.conf: a `*` line applies to every hack,
# then the hack's own line(s) -- later flags win in the hacks' arg parsers.
# Trailing ` # comment` is stripped. Args pass through one shell level inside
# the --command-each string.
hack_args() {
    [ -r "$HACKS_CONF" ] || return 0
    awk -v h="$1" '
        /^[[:space:]]*(#|$)/ { next }
        {
            line = $0
            sub(/[[:space:]]+#.*$/, "", line)
            n = split(line, f, /[[:space:]]+/)
            name = f[1]; args = ""
            for (i = 2; i <= n; i++) args = args (args == "" ? "" : " ") f[i]
            if (args == "") next
            if (name == "*") star = star (star == "" ? "" : " ") args
            if (name == h)   own  = own  (own  == "" ? "" : " ") args
        }
        END {
            out = star (star != "" && own != "" ? " " : "") own
            if (out != "") print out
        }' "$HACKS_CONF"
}

if [ -x "$HACK_DIR/$HACK" ] && [ -x "$WRAPPER" ]; then
    ARGS="$(hack_args "$HACK")"
    # --command-each runs one wallpaper instance per output. windowtolayer
    # adapts the Xwayland-hosted hack (via the wrapper) into a layer-shell
    # surface that swaylock-plugin composites as the lock background.
    exec swaylock-plugin --command-each \
        "windowtolayer '$WRAPPER' '$HACK_DIR/$HACK' -root${ARGS:+ $ARGS}"
fi

# No usable hack/wrapper: still lock (fail safe), just without the animation.
notify -u critical "swaylock-screensaver" \
    "no usable xscreensaver hack in $HACK_DIR -- locking without animation"
exec swaylock-plugin
